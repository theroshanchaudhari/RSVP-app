<%- include('partials/header', { title: 'Event Access' }) %>

<div class="container py-5" style="max-width:400px;">
  <div class="card shadow-sm">
    <div class="card-body p-4 text-center">
      <div style="font-size:3rem;">🔒</div>
      <h3 class="mt-3 fw-bold text-purple"><%= event.name %></h3>
      <p class="text-muted">This event page is password protected. Please enter the password to continue.</p>

      <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form action="/event-access" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="returnTo" value="<%= returnTo || '/' %>">
        <div class="mb-3">
          <input type="password" class="form-control form-control-lg text-center" name="password"
                 placeholder="Enter password" required autofocus>
        </div>
        <div class="d-grid">
          <button type="submit" class="btn btn-purple btn-lg">
            <i class="bi bi-unlock me-2"></i>Access Event
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
