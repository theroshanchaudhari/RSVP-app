<%- include('partials/header', { title: 'Edit Guest', activePage: 'guests' }) %>

<div class="mb-4">
  <a href="/admin/guests/<%= guest.id %>" class="text-muted text-decoration-none small">
    <i class="bi bi-arrow-left me-1"></i>Back to Guest
  </a>
  <h2 class="fw-bold text-purple mb-0 mt-1"><i class="bi bi-pencil me-2"></i>Edit: <%= guest.name %></h2>
</div>

<% if (errors && errors.length > 0) { %>
<div class="alert alert-danger">
  <ul class="mb-0"><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
</div>
<% } %>

<div class="card shadow-sm border-0" style="max-width:700px;">
  <div class="card-body p-4">
    <form action="/admin/guests/<%= guest.id %>/edit" method="POST">

      <h6 class="text-purple fw-bold mb-3">Guest Information</h6>
      <div class="row g-3 mb-4">
        <div class="col-12">
          <label class="form-label">Full Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control" name="name" value="<%= guest.name %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label">Email</label>
          <input type="email" class="form-control" name="email" value="<%= guest.email || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label">Phone</label>
          <input type="tel" class="form-control" name="phone" value="<%= guest.phone || '' %>">
        </div>
      </div>

      <h6 class="text-purple fw-bold mb-3">RSVP Details</h6>
      <div class="row g-3 mb-4">
        <div class="col-md-4">
          <label class="form-label">Attending</label>
          <select class="form-select" name="attending">
            <option value="yes" <%= guest.attending === 'yes' ? 'selected' : '' %>>Yes</option>
            <option value="no" <%= guest.attending === 'no' ? 'selected' : '' %>>No</option>
            <option value="maybe" <%= guest.attending === 'maybe' ? 'selected' : '' %>>Maybe</option>
            <option value="pending" <%= (guest.attending === 'pending' || !guest.attending) ? 'selected' : '' %>>Pending</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Adults</label>
          <input type="number" class="form-control" name="adults" value="<%= guest.adults %>" min="0" max="20">
        </div>
        <div class="col-md-4">
          <label class="form-label">Children</label>
          <input type="number" class="form-control" name="children" value="<%= guest.children %>" min="0" max="20">
        </div>
        <div class="col-md-6">
          <label class="form-label">Meal Preference</label>
          <select class="form-select" name="meal_preference">
            <option value="">No preference</option>
            <option value="Vegetarian" <%= guest.meal_preference === 'Vegetarian' ? 'selected' : '' %>>Vegetarian</option>
            <option value="Vegan" <%= guest.meal_preference === 'Vegan' ? 'selected' : '' %>>Vegan</option>
            <option value="Non-Vegetarian" <%= guest.meal_preference === 'Non-Vegetarian' ? 'selected' : '' %>>Non-Vegetarian</option>
            <option value="Jain" <%= guest.meal_preference === 'Jain' ? 'selected' : '' %>>Jain</option>
            <option value="Gluten-Free" <%= guest.meal_preference === 'Gluten-Free' ? 'selected' : '' %>>Gluten-Free</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">Dietary Restrictions</label>
          <input type="text" class="form-control" name="dietary_restrictions" value="<%= guest.dietary_restrictions || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label">Arrival Time</label>
          <input type="text" class="form-control" name="arrival_time" value="<%= guest.arrival_time || '' %>">
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Message</label>
        <textarea class="form-control" name="message" rows="2"><%= guest.message || '' %></textarea>
      </div>

      <div class="mb-4">
        <label class="form-label">Private Notes <small class="text-muted">(admin only)</small></label>
        <textarea class="form-control" name="private_notes" rows="2"><%= guest.private_notes || '' %></textarea>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-purple">
          <i class="bi bi-save me-2"></i>Save Changes
        </button>
        <a href="/admin/guests/<%= guest.id %>" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
