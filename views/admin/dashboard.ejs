<%- include('partials/header', { title: 'Dashboard', activePage: 'dashboard' }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="fw-bold text-purple mb-1"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>
    <p class="text-muted mb-0"><%= event.name %></p>
  </div>
  <div class="d-flex gap-2">
    <a href="/rsvp" target="_blank" class="btn btn-outline-purple btn-sm">
      <i class="bi bi-box-arrow-up-right me-1"></i>Public RSVP
    </a>
    <a href="/admin/guests/export/csv" class="btn btn-outline-success btn-sm">
      <i class="bi bi-download me-1"></i>Export CSV
    </a>
  </div>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-4">
  <div class="col-6 col-lg-3">
    <div class="card shadow-sm stat-card border-0">
      <div class="card-body text-center py-4">
        <div class="stat-icon text-purple"><i class="bi bi-people-fill"></i></div>
        <div class="stat-number text-purple"><%= stats.total %></div>
        <div class="text-muted small">Total RSVPs</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card shadow-sm stat-card border-0">
      <div class="card-body text-center py-4">
        <div class="stat-icon text-success"><i class="bi bi-check-circle-fill"></i></div>
        <div class="stat-number text-success"><%= stats.attending %></div>
        <div class="text-muted small">Attending</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card shadow-sm stat-card border-0">
      <div class="card-body text-center py-4">
        <div class="stat-icon text-danger"><i class="bi bi-x-circle-fill"></i></div>
        <div class="stat-number text-danger"><%= stats.notAttending %></div>
        <div class="text-muted small">Not Attending</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card shadow-sm stat-card border-0">
      <div class="card-body text-center py-4">
        <div class="stat-icon text-warning"><i class="bi bi-hourglass-split"></i></div>
        <div class="stat-number text-warning"><%= stats.pending %></div>
        <div class="text-muted small">Pending</div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card shadow-sm border-0">
      <div class="card-body text-center py-4">
        <div class="stat-icon text-info"><i class="bi bi-person-badge"></i></div>
        <div class="stat-number text-info"><%= stats.adults %></div>
        <div class="text-muted small">Total Adults (Attending)</div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card shadow-sm border-0">
      <div class="card-body text-center py-4">
        <div class="stat-icon text-info"><i class="bi bi-emoji-smile"></i></div>
        <div class="stat-number text-info"><%= stats.children %></div>
        <div class="text-muted small">Total Children (Attending)</div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card shadow-sm border-0">
      <div class="card-body text-center py-4">
        <div class="stat-icon text-purple"><i class="bi bi-people"></i></div>
        <div class="stat-number text-purple"><%= stats.adults + stats.children %></div>
        <div class="text-muted small">Total Expected Guests</div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mb-4">
  <!-- Meal Summary -->
  <div class="col-md-6">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white fw-bold">
        <i class="bi bi-fork-knife me-2 text-purple"></i>Meal Preference Summary
      </div>
      <div class="card-body p-0">
        <% if (stats.mealSummary.length === 0) { %>
          <p class="text-muted p-3 mb-0">No meal preferences recorded yet.</p>
        <% } else { %>
        <table class="table table-sm mb-0">
          <tbody>
            <% stats.mealSummary.forEach(m => { %>
            <tr>
              <td class="ps-3"><%= m.meal_preference %></td>
              <td class="text-end pe-3 fw-bold"><%= m.count %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Dietary Summary -->
  <div class="col-md-6">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white fw-bold">
        <i class="bi bi-heart-pulse me-2 text-purple"></i>Dietary Restrictions
      </div>
      <div class="card-body p-0">
        <% if (stats.dietarySummary.length === 0) { %>
          <p class="text-muted p-3 mb-0">No dietary restrictions recorded yet.</p>
        <% } else { %>
        <table class="table table-sm mb-0">
          <tbody>
            <% stats.dietarySummary.forEach(d => { %>
            <tr>
              <td class="ps-3"><%= d.dietary_restrictions %></td>
              <td class="text-end pe-3 fw-bold"><%= d.count %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- QR Code & Recent RSVPs -->
<div class="row g-4">
  <div class="col-md-4">
    <div class="card shadow-sm border-0 text-center">
      <div class="card-header bg-white fw-bold">
        <i class="bi bi-qr-code me-2 text-purple"></i>RSVP QR Code
      </div>
      <div class="card-body">
        <% if (qrCode) { %>
          <img src="<%= qrCode %>" alt="QR Code" class="img-fluid mb-2" style="max-width:180px;">
          <p class="text-muted small">Share this QR code for guests to RSVP</p>
          <a href="<%= rsvpUrl %>" target="_blank" class="btn btn-outline-purple btn-sm">
            <i class="bi bi-box-arrow-up-right me-1"></i><%= rsvpUrl %>
          </a>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-md-8">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-bold"><i class="bi bi-clock-history me-2 text-purple"></i>Recent RSVPs</span>
        <a href="/admin/guests" class="btn btn-outline-purple btn-sm">View All</a>
      </div>
      <div class="card-body p-0">
        <% if (recentGuests.length === 0) { %>
          <p class="text-muted p-3 mb-0">No RSVPs yet.</p>
        <% } else { %>
        <div class="table-responsive">
          <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Name</th>
                <th>Status</th>
                <th>Party</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% recentGuests.forEach(g => { %>
              <tr>
                <td><a href="/admin/guests/<%= g.id %>" class="text-decoration-none"><%= g.name %></a></td>
                <td>
                  <% if (g.attending === 'yes') { %><span class="badge bg-success">Attending</span>
                  <% } else if (g.attending === 'no') { %><span class="badge bg-danger">Not Attending</span>
                  <% } else if (g.attending === 'maybe') { %><span class="badge bg-warning text-dark">Maybe</span>
                  <% } else { %><span class="badge bg-secondary">Pending</span><% } %>
                </td>
                <td><%= g.adults %>A / <%= g.children %>C</td>
                <td class="text-muted small"><%= g.created_at ? g.created_at.substring(0, 10) : '-' %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
