<%- include('partials/header', { title: 'Add Guest', activePage: 'guests' }) %>

<div class="mb-4">
  <a href="/admin/guests" class="text-muted text-decoration-none small">
    <i class="bi bi-arrow-left me-1"></i>Back to Guests
  </a>
  <h2 class="fw-bold text-purple mb-0 mt-1"><i class="bi bi-person-plus me-2"></i>Add Guest Manually</h2>
</div>

<% if (errors && errors.length > 0) { %>
<div class="alert alert-danger">
  <ul class="mb-0"><% errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
</div>
<% } %>

<div class="card shadow-sm border-0" style="max-width:700px;">
  <div class="card-body p-4">
    <form action="/admin/guests/add" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <h6 class="text-purple fw-bold mb-3">Guest Information</h6>
      <div class="row g-3 mb-4">
        <div class="col-12">
          <label class="form-label">Full Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control" name="name" value="<%= formData.name || '' %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label">Email</label>
          <input type="email" class="form-control" name="email" value="<%= formData.email || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label">Phone</label>
          <input type="tel" class="form-control" name="phone" value="<%= formData.phone || '' %>">
        </div>
      </div>

      <h6 class="text-purple fw-bold mb-3">RSVP Details</h6>
      <div class="row g-3 mb-4">
        <div class="col-md-4">
          <label class="form-label">Attending</label>
          <select class="form-select" name="attending">
            <option value="yes" <%= formData.attending === 'yes' ? 'selected' : '' %>>Yes</option>
            <option value="no" <%= formData.attending === 'no' ? 'selected' : '' %>>No</option>
            <option value="maybe" <%= formData.attending === 'maybe' ? 'selected' : '' %>>Maybe</option>
            <option value="pending" <%= formData.attending === 'pending' ? 'selected' : '' %>>Pending</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Adults</label>
          <input type="number" class="form-control" name="adults" value="<%= formData.adults || 1 %>" min="0" max="20">
        </div>
        <div class="col-md-4">
          <label class="form-label">Children</label>
          <input type="number" class="form-control" name="children" value="<%= formData.children || 0 %>" min="0" max="20">
        </div>
        <div class="col-md-6">
          <label class="form-label">Meal Preference</label>
          <select class="form-select" name="meal_preference">
            <option value="">No preference</option>
            <option value="Vegetarian">Vegetarian</option>
            <option value="Vegan">Vegan</option>
            <option value="Non-Vegetarian">Non-Vegetarian</option>
            <option value="Jain">Jain</option>
            <option value="Gluten-Free">Gluten-Free</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">Dietary Restrictions</label>
          <input type="text" class="form-control" name="dietary_restrictions" value="<%= formData.dietary_restrictions || '' %>">
        </div>
        <div class="col-md-6">
          <label class="form-label">Arrival Time</label>
          <input type="text" class="form-control" name="arrival_time" value="<%= formData.arrival_time || '' %>" placeholder="e.g. 11:00 AM">
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Message</label>
        <textarea class="form-control" name="message" rows="2"><%= formData.message || '' %></textarea>
      </div>

      <div class="mb-4">
        <label class="form-label">Private Notes <small class="text-muted">(admin only)</small></label>
        <textarea class="form-control" name="private_notes" rows="2" placeholder="Notes visible only to you..."><%= formData.private_notes || '' %></textarea>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-purple">
          <i class="bi bi-person-plus me-2"></i>Add Guest
        </button>
        <a href="/admin/guests" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
