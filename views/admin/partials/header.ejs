<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' – ' : '' %>Admin | <%= event.name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">

<div class="d-flex min-vh-100">
  <!-- Sidebar -->
  <nav class="admin-sidebar d-flex flex-column p-3" style="width:240px; min-height:100vh;">
    <a href="/admin" class="text-white text-decoration-none mb-4 mt-2">
      <span class="fs-5 fw-bold"><i class="bi bi-calendar-heart me-2"></i>RSVP Admin</span>
    </a>
    <ul class="nav nav-pills flex-column gap-1">
      <li class="nav-item">
        <a href="/admin" class="nav-link text-white-50 <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active-nav' : '' %>">
          <i class="bi bi-speedometer2 me-2"></i>Dashboard
        </a>
      </li>
      <li class="nav-item">
        <a href="/admin/guests" class="nav-link text-white-50 <%= typeof activePage !== 'undefined' && activePage === 'guests' ? 'active-nav' : '' %>">
          <i class="bi bi-people me-2"></i>Guests
        </a>
      </li>
      <li class="nav-item">
        <a href="/admin/invitations" class="nav-link text-white-50 <%= typeof activePage !== 'undefined' && activePage === 'invitations' ? 'active-nav' : '' %>">
          <i class="bi bi-envelope me-2"></i>Invitations
        </a>
      </li>
      <li class="nav-item">
        <a href="/admin/settings" class="nav-link text-white-50 <%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'active-nav' : '' %>">
          <i class="bi bi-gear me-2"></i>Settings
        </a>
      </li>
    </ul>
    <div class="mt-auto">
      <a href="/" target="_blank" class="nav-link text-white-50 small">
        <i class="bi bi-box-arrow-up-right me-1"></i>View Event Page
      </a>
      <form action="/admin/logout" method="POST" class="mt-1">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="nav-link text-white-50 btn btn-link p-0 small">
          <i class="bi bi-box-arrow-right me-1"></i>Logout
        </button>
      </form>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="flex-grow-1 p-4" style="overflow-x:auto;">
