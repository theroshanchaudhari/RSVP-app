<%- include('partials/header', { title: 'RSVP Closed' }) %>
<div class="container py-5 text-center" style="max-width:500px;">
  <div style="font-size:4rem;">⏰</div>
  <h2 class="mt-3 text-purple fw-bold">RSVP is Closed</h2>
  <p class="lead text-muted">The RSVP deadline for <strong><%= event.name %></strong> has passed.</p>
  <% if (event.rsvp_deadline) { %><p class="text-muted">Deadline was: <strong><%= event.rsvp_deadline %></strong></p><% } %>
  <a href="/" class="btn btn-purple mt-3"><i class="bi bi-house me-2"></i>Back to Event</a>
</div>
<%- include('partials/footer') %>
